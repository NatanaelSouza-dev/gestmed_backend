{
	"name": "gestmed-exams-backend",
	"version": "1.0.0",
	"description": "Backend para gestão de exames médicos",
	"main": "dist/server.js",
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"build": "tsc",
		"format": "biome format --write src prisma package.json tsconfig.json",
		"start": "node dist/src/server.js",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:seed": "tsx prisma/seed.ts",
		"db:studio": "prisma studio"
	},
	"prisma": {
		"seed": "tsx prisma/seed.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.600.0",
		"@aws-sdk/s3-request-presigner": "^3.600.0",
		"@fastify/cors": "^9.0.1",
		"@fastify/jwt": "^8.0.1",
		"@fastify/multipart": "^8.3.0",
		"@fastify/rate-limit": "^9.1.0",
		"@prisma/client": "^5.16.0",
		"bcryptjs": "^2.4.3",
		"dotenv": "^16.4.5",
		"fastify": "^4.28.1",
		"fastify-plugin": "^4.5.1",
		"pdfkit": "^0.15.0",
		"resend": "^3.4.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/bcryptjs": "^2.4.6",
		"@types/node": "^20.14.0",
		"@types/pdfkit": "^0.13.4",
		"prisma": "^5.16.0",
		"tsx": "^4.16.0",
		"typescript": "^5.5.0"
	}
}
